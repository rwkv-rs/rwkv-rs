# Shared external judge/checker API.
RWKV_EVAL_EXT_MODEL=gemini-3-flash-preview
RWKV_EVAL_EXT_MODELS=gemini-3-flash-preview,deepseek-r1-250528,gpt-5.2-2025-12-11,gemini-3.1-pro-preview,gemini-2.5-flash,gpt-5-2025-08-07
RWKV_EVAL_EXT_BASE_URL=https://reelxai.com/v1
RWKV_EVAL_EXT_API_KEY=replace_with_real_api_key

# Optional target-model override when a [[models]] entry uses env_override_required.
# Use this for a local RWKV inference server while keeping judge/checker on the external API above.
# RWKV_EVAL_TARGET_MODEL=rwkv7-g1d-7.2b
# RWKV_EVAL_TARGET_BASE_URL=http://127.0.0.1:8080
# RWKV_EVAL_TARGET_API_KEY=local

# Optional role-specific overrides. Leave unset to inherit RWKV_EVAL_EXT_*.
# RWKV_EVAL_LLM_JUDGER_MODEL=
# RWKV_EVAL_LLM_JUDGER_BASE_URL=
# RWKV_EVAL_LLM_JUDGER_API_KEY=
# RWKV_EVAL_LLM_CHECKER_MODEL=
# RWKV_EVAL_LLM_CHECKER_BASE_URL=
# RWKV_EVAL_LLM_CHECKER_API_KEY=

# Optional ordered fallback lists. First healthy model wins.
# RWKV_EVAL_LLM_JUDGER_MODELS=
# RWKV_EVAL_LLM_CHECKER_MODELS=

# PostgreSQL connection used by rwkv-lm-eval when upload_to_space=true.
RWKV_EVAL_SPACE_DB_HOST=127.0.0.1
RWKV_EVAL_SPACE_DB_PORT=5432
RWKV_EVAL_SPACE_DB_USERNAME=postgres
RWKV_EVAL_SPACE_DB_PASSWORD=replace_with_real_password
RWKV_EVAL_SPACE_DB_DATABASE_NAME=rwkv_eval
RWKV_EVAL_SPACE_DB_SSLMODE=disable
