# Shared external judge/checker API.
RWKV_EVAL_EXT_MODEL=MiniMax-M2.5
RWKV_EVAL_EXT_BASE_URL=https://api.ablai.top/v1
RWKV_EVAL_EXT_API_KEY=replace_with_real_api_key

# Optional role-specific overrides. Leave unset to inherit RWKV_EVAL_EXT_*.
# RWKV_EVAL_LLM_JUDGER_MODEL=
# RWKV_EVAL_LLM_JUDGER_BASE_URL=
# RWKV_EVAL_LLM_JUDGER_API_KEY=
# RWKV_EVAL_LLM_CHECKER_MODEL=
# RWKV_EVAL_LLM_CHECKER_BASE_URL=
# RWKV_EVAL_LLM_CHECKER_API_KEY=

# PostgreSQL connection used by rwkv-lm-eval when upload_to_space=true.
RWKV_EVAL_SPACE_DB_HOST=127.0.0.1
RWKV_EVAL_SPACE_DB_PORT=5432
RWKV_EVAL_SPACE_DB_USERNAME=postgres
RWKV_EVAL_SPACE_DB_PASSWORD=replace_with_real_password
RWKV_EVAL_SPACE_DB_DATABASE_NAME=rwkv_eval
RWKV_EVAL_SPACE_DB_SSLMODE=disable
